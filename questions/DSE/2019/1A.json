      "options": [
        {
          "label": "A",
          "text": "\\( \\mathrm{NaHCO_{3}(s)\\rightarrow NaOH(s)+CO_{2}(g)} \\)",
          "image": null
        },
        {
          "label": "B",
          "text": "\\( 2\\mathrm{NaHCO}_{3}(\\mathrm{s}) \\rightarrow \\mathrm{Na}_{2}\\mathrm{O}_{2}(\\mathrm{s}) + 2\\mathrm{CO}_{2}(\\mathrm{g}) + \\mathrm{H}_{2}(\\mathrm{g}) \\)",
          "image": null
        },
        {
          "label": "C",
          "text": "\\( 2\\mathrm{NaHCO}_{3}(\\mathrm{s}) \\rightarrow \\mathrm{CaCO}_{3}(\\mathrm{s}) + \\mathrm{H}_{2}\\mathrm{O}(\\mathrm{g}) + \\mathrm{CO}_{2}(\\mathrm{g}) \\)",
          "image": null
        },
        {
          "label": "D",
          "text": "\\( 2\\mathrm{NaHCO}_{3}(\\mathrm{s}) \\rightarrow \\mathrm{O}_{2}(\\mathrm{s}) + \\mathrm{H}_{2}\\mathrm{O}(\\mathrm{g}) + 2\\mathrm{CO}_{2}(\\mathrm{g}) \\)",
          "image": null
        }
      ],
      "answer": "C",
      "source_folder": "C:\\Users\\user\\Desktop\\outputocr\\Scanned_dse2019chempaper1mc\\page_0002"
    },
